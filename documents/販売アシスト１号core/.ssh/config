host *
	StrictHostKeyChecking no
	UserKnownHostsFile=/dev/null

host github.com
	Hostname ssh.github.com
	Port 443
	IdentityFile ~/.ssh/id_ed25519

host cyb0
        hostname www.cyberius.biz
	port 5000
	user osa

host git.cyberius.biz
  IdentityFile ~/.ssh/id_ed25519
  ProxyJump cyb0
  StrictHostKeyChecking no
  UserKnownHostsFile=/dev/null

host pve1
        hostname 192.168.0.252
        port 22
        user root
host git
	hostname 192.168.99.120
	port 22
	user root
	
