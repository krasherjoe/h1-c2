# Google OAuth Client ID
# Google Cloud Console → 認証情報 → OAuth 2.0 クライアントID (Web アプリケーション型)
# iOS/Web ビルド時のみ必要。Android は strings.xml の default_web_client_id が使われる。
#
# 使い方:
#   cp .env.example .env
#   # .env に実際の Client ID を記入
#   flutter build apk --release --dart-define-from-file=.env
#
GOOGLE_CLIENT_ID=
